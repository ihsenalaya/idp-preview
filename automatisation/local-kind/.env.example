# =============================================================================
# Variables d'environnement de la plateforme locale (kind + GitHub Models).
# Copier en `.env` puis remplir. JAMAIS committer `.env` (ignore par .gitignore).
#
#   cp .env.example .env && $EDITOR .env
# =============================================================================

# --- GitHub --------------------------------------------------------------------
# PAT GitHub classique (ou fine-grained) avec les scopes :
#   repo            -> commentaires de PR, deployments, enregistrement runner
# (read:packages inutile : les images GHCR de la plateforme sont publiques.)
# Utilise par : preview-operator (commentaires PR), github-mcp-server, runner.
GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Token pour les GitHub Models (gratuit). Doit porter le scope `models:read`
# (PAT fine-grained -> permission "Models: read", ou un classic PAT recent).
# Endpoint : https://models.github.ai/inference  (OpenAI-compatible).
# Peut etre identique a GITHUB_TOKEN si ce dernier a deja `models:read`.
# Consomme par : preview-operator (AI enrichment) ET kagent (agents IA).
GITHUB_MODELS_TOKEN="${GITHUB_TOKEN}"

# Depot GitHub a previewer (le runner s'y enregistre comme self-hosted).
GITHUB_REPO_URL="https://github.com/ihsenalaya/idp-preview"

# --- GitOps (ArgoCD) -----------------------------------------------------------
# Depot + branche que ArgoCD suit pour les manifests de CETTE automatisation.
# Les fichiers de automatisation/local-kind/ DOIVENT etre pousses sur cette
# branche pour qu'ArgoCD puisse les recuperer. Voir README.md (etape 0).
GIT_REPO_URL="https://github.com/ihsenalaya/idp-preview"
GIT_REVISION="local-kind"

# --- Modeles -------------------------------------------------------------------
# Sur l'endpoint models.github.ai, les modeles sont nommes avec le prefixe
# de l'editeur (ex. openai/gpt-4o-mini, openai/gpt-4o, meta/Llama-3.3-70B-Instruct).
AI_MODEL="openai/gpt-4o-mini"
